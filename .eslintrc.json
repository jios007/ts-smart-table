{
  "env": {
    "browser": true,
    "es6": true
  },
  "plugins": ["powerbi-visuals"],
  "extends": ["plugin:powerbi-visuals/recommended"],
  "parserOptions": {
    "ecmaVersion": 2018,
    "sourceType": "module"
  },
  "ignorePatterns": ["dist/", ".tmp/", "node_modules/"],
  "rules": {
    "powerbi-visuals/no-banned-terms": "error"
  }
}
